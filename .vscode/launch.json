{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: EditorReportesBack",
      "runtimeExecutable": "${workspaceFolder}/EditorReportesBack/node_modules/.bin/tsx",
      "runtimeArgs": ["watch", "src/index.ts"],
      "cwd": "${workspaceFolder}/EditorReportesBack",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: pdf-service",
      "runtimeExecutable": "${workspaceFolder}/pdf-service/node_modules/.bin/tsx",
      "runtimeArgs": ["watch", "src/server.ts"],
      "cwd": "${workspaceFolder}/pdf-service",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug: EditorReportes (React)",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/EditorReportes"
    }
  ]
}