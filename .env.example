# =============================================================================
# .env.example — Variables de entorno del proyecto
# Organizadas por servicio. Copiar a .env y ajustar para producción.
# =============================================================================


# ═════════════════════════════════════════════════════════════════════════════
# DOCKER COMPOSE (raíz) — Configuración de infraestructura
# ═════════════════════════════════════════════════════════════════════════════
MONGO_USER=admin
MONGO_PASS=password123
POSTGRES_USER=admin
POSTGRES_PASS=password123
# Puerto HTTP del reverse proxy
HTTP_PORT=80
# Puerto HTTPS (opcional, requiere SSL)
HTTPS_PORT=443
# CAMBIAR: app.tudominio.com
NGINX_FRONTEND_SERVER_NAME=_
# CAMBIAR: api.tudominio.com
NGINX_API_SERVER_NAME=_
# Upstream del frontend
NGINX_FRONTEND_UPSTREAM=pdf-frontend:80
# Docker Compose expande
NGINX_BACKEND_UPSTREAM=pdf-backend:${API_PORT}
# Tamaño máximo de body en nginx
NGINX_CLIENT_MAX_BODY_SIZE=100M
# Ruta al JSON de service account de GCP
GCP_KEY_FILE=


# ═════════════════════════════════════════════════════════════════════════════
# BACKEND (EditorReportesBack) — Express + Apollo Server + BullMQ
# ═════════════════════════════════════════════════════════════════════════════

## --- Generales ---
# production | development
NODE_ENV=production
# Puerto del backend (único)
API_PORT=4000

## --- Bases de datos ---
MONGODB_URI=mongodb://admin:password123@localhost:27017/pdf_templates?authSource=admin&directConnection=true
POSTGRES_URI=postgresql://admin:password123@localhost:5432/pdf_auth

## --- Redis (para BullMQ y SSE) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Dejar vacío si no tiene contraseña
REDIS_PASSWORD=
REDIS_DB=0

## --- URL base de la API ---
# CAMBIAR: https://api.tudominio.com
API_URL=http://localhost:${API_PORT}

## --- URLs de servicios ---
# CAMBIAR: https://api.tudominio.com
BASE_URL=http://localhost:${API_PORT}
# URL del pdf-service (cambia en Docker a http://pdf-service:3001)
PDF_SERVICE_URL=http://localhost:3001
# CAMBIAR: https://app.tudominio.com
FRONTEND_URL=http://localhost:5174

## --- JWT ---
JWT_SECRET=my-super-secret-key-123456
JWT_REFRESH_SECRET=my-super-refresh-secret-key-123456

## --- ALTCHA (anti-bot en registro/login) ---
ALTCHA_HMAC_KEY="clave_secreta_para_altcha"

## --- Modo del proyecto ---
# saas | local (local desactiva API keys y suscripciones)
PROJECT_MODE=saas

## --- Rate Limit ---
# true | false
ENABLE_RATE_LIMIT=true
# Máximo de PDFs por hora por API key
PDF_LIMIT_PER_HOUR=100

## --- Cola de PDF (BullMQ Worker) ---
# Jobs simultáneos
QUEUE_CONCURRENCY=3
# Tiempo máximo por job (ms) — 5 min
QUEUE_DURATION=310000
# Delay entre reintentos (ms)
QUEUE_DELAY=500
# Reintentos antes de fallar
QUEUE_ATTEMPTS=3
# Renovación de lock (ms)
QUEUE_LOCK_RENEW_TIME=15000

## --- Usuario por defecto ---
# Password para restablecer/crear usuarios
DEFAULT_USER_PASSWORD=contrasena123

## --- Google Cloud Storage (solo si PROJECT_MODE=saas y usas GCP) ---
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
# Ruta absoluta al JSON dentro del contenedor (en Docker: /run/secrets/gcp-key)
GCP_KEY_PATH=

## --- Brevo (emails transaccionales) ---
USE_BREVO=true                # true | false
BREVO_API_KEY=
BREVO_SENDER_MAIL=contacto@ejemplo.com
BREVO_SENDER_NAME="PDF Service"

## --- Seguridad ---
# Intentos máximos de recuperación de contraseña en 24h
MAX_RECOVERY_ATTEMPTS_24H=3
# Secreto para firmar webhooks
WEBHOOK_SECRET=fallback_secret

## --- Cron Jobs ---
# Cada minuto (en prod, cambiar a algo menos frecuente)
CLEANUP_CRON_SCHEDULE=*/1 * * * *

## --- PDF Generation ---
# Ignorar SSL en imágenes inline (desarrollo)
INLINE_IMAGES_IGNORE_SSL=true
# Permitir webhooks con SSL autofirmado
WEBHOOK_ALLOW_SELFSIGNED=true

## --- CORS ---
# CAMBIAR: https://app.tudominio.com
CORS_ORIGIN=http://localhost:3000


# ═════════════════════════════════════════════════════════════════════════════
# PDF SERVICE (pdf-service) — Motor de conversión HTML → PDF
# ═════════════════════════════════════════════════════════════════════════════
# Nota: no se pasan al pdf-service en docker-compose.yml actualmente.
# El pdf-service usa sus propios defaults internos.
# PDF_SERVICE_PORT=3001
# WEASYPRINT_PATH=weasyprint
# WEASYPRINT_TIMEOUT=60000     # Timeout de conversión (ms)


# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND (EditorReportes) — React + Vite
# ═════════════════════════════════════════════════════════════════════════════
# Variables BUILD-TIME de Vite. Se definen en el .env raíz para desarrollo local.
# En Docker se inyectan via ARG en el Dockerfile (rutas relativas por nginx).
#
VITE_API_URL=http://localhost:${API_PORT}            # Referencia

# Vacío = relativo (nginx). En prod: https://api.tudominio.com
VITE_API_BACK_URL=
# En prod: https://api.tudominio.com/graphql
VITE_GRAPHQL_URL=/graphql
# En prod: https://api.tudominio.com/api/pdf
VITE_API_PDF_URL=/api/pdf
VITE_PROJECT_MODE=saas
